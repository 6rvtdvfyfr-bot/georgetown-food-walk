# Copy this file to .env.local (already gitignored) and fill in real values.

# Same Project URL used in index.html.
SUPABASE_URL=https://ahkhiqrrogirebhtgjbf.supabase.co

# Same anon public key used in index.html — safe to reuse, not a secret.
SUPABASE_ANON_KEY=

# Your own short-lived access token from a signed-in browser session (NOT a
# permanent secret — expires after about an hour). See README.md for how to
# grab it. Using your own session token (rather than the Supabase service
# role key) keeps this script scoped to exactly what the app already lets
# you read — no broader admin access.
SUPABASE_USER_ACCESS_TOKEN=
